# ── SMTP / Email ───────────────────────────────────────────
# Your SMTP server host (e.g., smtp.gmail.com, smtp.sendgrid.net)
SMTP_HOST=

# SMTP port (587 for STARTTLS, 465 for SSL)
SMTP_PORT=587

# Your full email address used as login
SMTP_USER=

# App password or SMTP API key
SMTP_PASS=

# Optional — the "From" name & address (defaults to SMTP_USER)
FROM_NAME=Double Agent
FROM_EMAIL=

# ── Scraper ───────────────────────────────────────────────
# Set to "false" to watch the browser in action (debug mode)
HEADLESS=true

# ── Sender Limits ──────────────────────────────────────────
DAILY_EMAIL_LIMIT=30
DELAY_MIN_SECONDS=60
DELAY_MAX_SECONDS=180
